# Default model (used when client doesn't specify)
DEFAULT_MODEL=gpt-5.2

# Fallback model for Gemini (cheap routing mode uses this)
DEFAULT_GEMINI_MODEL=gemini-2.5-flash

# Fallback model for Anthropic (quality routing mode uses this)
DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-6

# Database — use pooled connection string from Neon dashboard (contains "pooler" in URL)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/db?pgbouncer=true&connect_timeout=10

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Upstash Vector (semantic cache — create index with text-embedding-3-small in Upstash console)
UPSTASH_VECTOR_REST_URL=https://xxx-vector.upstash.io
UPSTASH_VECTOR_REST_TOKEN=xxx
SEMANTIC_CACHE_THRESHOLD=0.97     # optional, default 0.97 (0=any match, 1=exact only)

# AI Provider Keys — use comma-separated list for key rotation (single key also works)
OPENAI_KEYS=sk-key1,sk-key2         # or: OPENAI_API_KEY=sk-...
GEMINI_KEYS=key1,key2               # or: GEMINI_API_KEY=...
ANTHROPIC_KEYS=sk-ant-key1          # or: ANTHROPIC_API_KEY=sk-ant-...

# Provider Base URLs (optional — override for testing or custom endpoints)
OPENAI_BASE_URL=https://api.openai.com
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Provider Timeouts
PROVIDER_TIMEOUT_MS=10000    # 10s for regular requests
STREAM_TIMEOUT_MS=30000      # 30s inactivity timeout for streaming

# Auth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://yourdomain.com

# CORS — dashboard origin only
DASHBOARD_URL=https://app.yourdomain.com

# Cache
CACHE_TTL_SECONDS=86400        # free plan TTL (24hr)
ENTERPRISE_TTL_SECONDS=604800  # enterprise plan TTL (7 days, configurable)

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
